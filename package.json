{
  "name": "cc-panel",
  "displayName": "CC Panel",
  "description": "Panel sterujący 1-4 sesjami Claude Code w obszarze edytora VS Code",
  "version": "0.0.4",
  "publisher": "LokalnaAutomatyzacjaBiznesu",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tftdatascientist/cc-panel.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onCommand:ccPanel.open", "onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccPanel.open",
        "title": "CC Panel: Open"
      },
      {
        "command": "ccPanel.addTerminal",
        "title": "CC Panel: Add Terminal"
      },
      {
        "command": "ccPanel.cycleActive",
        "title": "CC Panel: Cycle Active Terminal"
      },
      {
        "command": "ccPanel.editUserCommands",
        "title": "CC Panel: Edit User Commands"
      },
      {
        "command": "ccPanel.editMessages",
        "title": "CC Panel: Edit Messages"
      },
      {
        "command": "ccPanel.reloadUserLists",
        "title": "CC Panel: Reload ustawienia.json"
      },
      {
        "command": "ccPanel.installHooks",
        "title": "CC Panel: Install Hooks"
      },
      {
        "command": "ccPanel.setProjectFolder",
        "title": "CC Panel: Ustaw folder projektu"
      },
      {
        "command": "ccPanel.selectTerminal1",
        "title": "CC Panel: Select Terminal 1"
      },
      {
        "command": "ccPanel.selectTerminal2",
        "title": "CC Panel: Select Terminal 2"
      },
      {
        "command": "ccPanel.selectTerminal3",
        "title": "CC Panel: Select Terminal 3"
      },
      {
        "command": "ccPanel.selectTerminal4",
        "title": "CC Panel: Select Terminal 4"
      },
      {
        "command": "ccPanel.startAutoAccept",
        "title": "CC Panel: Start Auto-Accept"
      },
      {
        "command": "ccPanel.stopAutoAccept",
        "title": "CC Panel: Stop Auto-Accept"
      },
      {
        "command": "ccPanel.editAutoAcceptSystemPrompt",
        "title": "CC Panel: Edit Auto-Accept System Prompt"
      },
      {
        "command": "ccPanel.showAutoAcceptHistory",
        "title": "CC Panel: Show Auto-Accept History"
      },
      {
        "command": "ccPanel.autoAcceptStatus",
        "title": "CC Panel: Auto-Accept Status"
      }
    ],
    "keybindings": [
      {
        "command": "ccPanel.startAutoAccept",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "ccPanel.cycleActive",
        "key": "ctrl+alt+`",
        "mac": "cmd+alt+`"
      },
      {
        "command": "ccPanel.selectTerminal1",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1"
      },
      {
        "command": "ccPanel.selectTerminal2",
        "key": "ctrl+alt+2",
        "mac": "cmd+alt+2"
      },
      {
        "command": "ccPanel.selectTerminal3",
        "key": "ctrl+alt+3",
        "mac": "cmd+alt+3"
      },
      {
        "command": "ccPanel.selectTerminal4",
        "key": "ctrl+alt+4",
        "mac": "cmd+alt+4"
      },
      {
        "command": "ccPanel.selectTerminal1",
        "key": "f1",
        "when": "activeWebviewPanelId == 'ccPanel'"
      },
      {
        "command": "ccPanel.selectTerminal2",
        "key": "f2",
        "when": "activeWebviewPanelId == 'ccPanel'"
      },
      {
        "command": "ccPanel.selectTerminal3",
        "key": "f3",
        "when": "activeWebviewPanelId == 'ccPanel'"
      },
      {
        "command": "ccPanel.selectTerminal4",
        "key": "f4",
        "when": "activeWebviewPanelId == 'ccPanel'"
      }
    ],
    "colors": [
      {
        "id": "ccPanel.terminal.t1",
        "description": "CC Panel — kolor terminala T1 (ikona w tabie).",
        "defaults": { "dark": "#14b8a6", "light": "#14b8a6", "highContrast": "#14b8a6" }
      },
      {
        "id": "ccPanel.terminal.t2",
        "description": "CC Panel — kolor terminala T2 (ikona w tabie).",
        "defaults": { "dark": "#f59e0b", "light": "#f59e0b", "highContrast": "#f59e0b" }
      },
      {
        "id": "ccPanel.terminal.t3",
        "description": "CC Panel — kolor terminala T3 (ikona w tabie).",
        "defaults": { "dark": "#a78bfa", "light": "#a78bfa", "highContrast": "#a78bfa" }
      },
      {
        "id": "ccPanel.terminal.t4",
        "description": "CC Panel — kolor terminala T4 (ikona w tabie).",
        "defaults": { "dark": "#fb7185", "light": "#fb7185", "highContrast": "#fb7185" }
      }
    ],
    "configuration": {
      "title": "CC Panel",
      "properties": {
        "ccPanel.command": {
          "type": "string",
          "default": "claude",
          "description": "Komenda CLI spawnowana w każdym terminalu (np. 'claude', 'cc'). Musi być widoczna w PATH z poziomu cmd.exe (Windows) / sh (macOS/Linux)."
        },
        "ccPanel.bypassPermissions": {
          "type": "boolean",
          "default": true,
          "description": "Uruchom CC z flagą --dangerously-skip-permissions (brak pytań o uprawnienia narzędzi)."
        },
        "ccPanel.autoAcceptSystemPrompt": {
          "type": "string",
          "default": "You are an auto-accept assistant for a Claude Code session. You receive the recent conversation and must respond with a short, direct reply that would continue the work productively. Keep it under 200 characters. If the conversation is stuck in a loop or asks a question you cannot answer, respond with 'stop'.",
          "description": "System prompt dla Haiku w Auto-Accept mode. Sterowanie zachowaniem modelu gdy CC czeka na odpowiedź."
        },
        "ccPanel.autoAcceptMetaPrompt": {
          "type": "string",
          "default": "Based on the recent conversation above, respond in a way that keeps the work moving forward.",
          "description": "Meta-prompt dla Haiku — dołączany po kontekście transcriptu przy każdej iteracji AA."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.config.js --production",
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "compile-types": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}
